# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=ars_user
POSTGRES_PASSWORD=ars_password
POSTGRES_DB=ars_db

# ─── Auth ──────────────────────────────────────────────────────────────────
# IMPORTANT: Change this in production! Minimum 32 characters.
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── MinIO (resume PDF storage — S3-compatible, runs in Docker) ────────────
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123456
MINIO_BUCKET=ars-resumes
# Public URL used in stored resume links — must be reachable from the browser
MINIO_PUBLIC_URL=http://localhost:9000

# ─── Anthropic Claude API ───────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Rate Limiting (api-gateway) ───────────────────────────────────────────
# TTL in SECONDS (nestjs/throttler v5 uses seconds, not ms). Default: 60 (1 minute)
THROTTLE_TTL=60
# Max requests per TTL window. Default: 100
THROTTLE_LIMIT=100

# ─── Logging ───────────────────────────────────────────────────────────────
# Log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# ─── SMTP / Email Notifications ────────────────────────────────────────────
# Used by ai-screener-service to notify recruiters after screening completes.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
