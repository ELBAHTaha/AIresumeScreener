# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=ars_user
POSTGRES_PASSWORD=ars_password
POSTGRES_DB=ars_db

# ─── Auth ──────────────────────────────────────────────────────────────────
# IMPORTANT: Change this in production! Minimum 32 characters.
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── AWS S3 (resume PDF storage) ───────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=ars-resumes

# ─── Anthropic Claude API ───────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Rate Limiting (api-gateway) ───────────────────────────────────────────
# TTL in milliseconds. Default: 60000 (60 seconds)
THROTTLE_TTL=60000
# Max requests per TTL window. Default: 10
THROTTLE_LIMIT=10

# ─── Logging ───────────────────────────────────────────────────────────────
# Log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# ─── SMTP / Email Notifications ────────────────────────────────────────────
# Used by ai-screener-service to notify recruiters after screening completes.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
